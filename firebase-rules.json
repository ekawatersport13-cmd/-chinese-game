{
  "rules": {
    "rooms": {
      ".read": true,
      ".write": true,
      ".indexOn": ["hasGuest"]
    },

    "players": {
      ".read": true,
      ".write": true,
      "$deviceId": {
        ".validate": "newData.hasChildren(['lastActiveStr', 'platform'])",
        "totalGames": { ".validate": "newData.isNumber()" },
        "totalPlayTimeMinutes": { ".validate": "newData.isNumber()" },
        "totalScore": { ".validate": "newData.isNumber()" },
        "lastScore": { ".validate": "newData.isNumber()" },
        "lastGameMode": { ".validate": "newData.isString()" },
        "lastActive": {},
        "lastActiveStr": {},
        "lastVisitAt": {},
        "lastVisitAtStr": {},
        "platform": {},
        "language": {},
        "isMobile": {},
        "lastVisitPlatform": {}
      }
    },

    "visits": {
      ".read": true,
      ".write": true,
      "$deviceId": {
        ".validate": "newData.hasChildren(['lastVisitStr', 'platform'])",
        "$timestamp": { ".validate": "true" }
      }
    },

    "gameSessions": {
      ".read": true,
      ".write": true,
      "$deviceId": {
        "$sessionId": {
          ".validate": "newData.hasChildren(['gameMode', 'startedAt']) || newData.hasChildren(['endedAt'])"
        }
      }
    },

    "gameRecords": {
      ".read": true,
      ".write": true
    }
  }
}
